# Model provider configuration for the future backend runtime.
# The dashboard should never read these values directly.

AUTO_AGENT_PROVIDER=openai-compatible
AUTO_AGENT_BASE_URL=https://api.openai.com/v1
AUTO_AGENT_API_KEY=
AUTO_AGENT_MODEL=

# SQLite database path for persisted goal/run/step/event state.
AUTO_AGENT_DATABASE_PATH=data/auto-agent.sqlite
