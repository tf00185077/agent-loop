{
  "name": "auto-agent",
  "version": "1.0.0",
  "description": "Goal-driven agent loop dashboard and runtime",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "dev:api": "tsx watch src/backend/server.ts",
    "dev:web": "vite --config src/dashboard/vite.config.ts",
    "dev": "node scripts/dev.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
